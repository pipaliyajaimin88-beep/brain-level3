#!/bin/bash

# Write package.json
cat > package.json << 'JSON'
{
  "name": "brainlevel",
  "version": "1.0.0",
  "dependencies": {
    "@capacitor/android": "5.7.4",
    "@capacitor/cli": "5.7.4",
    "@capacitor/core": "5.7.4"
  }
}
JSON

# Write capacitor.config.json
cat > capacitor.config.json << 'JSON'
{
  "appId": "com.brainlevel.game",
  "appName": "BrainLevel",
  "webDir": "www"
}
JSON

# Create www and copy files
mkdir -p www
for f in index.html game-logic.js styles.css levels.json manifest.json; do
  [ -f "$f" ] && cp "$f" www/ && echo "copied $f"
done

# Install packages
npm install --legacy-peer-deps
npm install -g @capacitor/cli@5.7.4

# Add android platform
rm -rf android
npx cap add android
npx cap sync android

# Copy missing gradle files from node_modules
SRC="node_modules/@capacitor/android/capacitor"

if [ ! -f android/capacitor.settings.gradle ]; then
  if [ -f "$SRC/capacitor.settings.gradle" ]; then
    cp "$SRC/capacitor.settings.gradle" android/capacitor.settings.gradle
    echo "copied capacitor.settings.gradle"
  else
    printf "include ':capacitor-android'\nproject(':capacitor-android').projectDir = new File('../node_modules/@capacitor/android/capacitor')\n" > android/capacitor.settings.gradle
    echo "created capacitor.settings.gradle"
  fi
fi

if [ ! -f android/app/capacitor.build.gradle ]; then
  if [ -f "$SRC/capacitor.build.gradle" ]; then
    cp "$SRC/capacitor.build.gradle" android/app/capacitor.build.gradle
    echo "copied capacitor.build.gradle"
  else
    printf "dependencies {}\n" > android/app/capacitor.build.gradle
    echo "created capacitor.build.gradle"
  fi
fi

if [ ! -f android/variables.gradle ]; then
  cat > android/variables.gradle << 'GRADLE'
ext {
  minSdkVersion = 22
  compileSdkVersion = 34
  targetSdkVersion = 34
  androidxActivityVersion = '1.8.0'
  androidxAppCompatVersion = '1.6.1'
  androidxCoordinatorLayoutVersion = '1.2.0'
  androidxCoreVersion = '1.12.0'
  androidxFragmentVersion = '1.6.2'
  junitVersion = '4.13.2'
  androidxJunitVersion = '1.1.5'
  androidxEspressoCoreVersion = '3.5.1'
  cordovaAndroidVersion = '10.1.1'
}
GRADLE
  echo "created variables.gradle"
fi

# Fix gradle memory settings
cat > android/gradle.properties << 'PROPS'
org.gradle.jvmargs=-Xmx1536m -XX:MaxMetaspaceSize=512m
org.gradle.daemon=false
org.gradle.parallel=false
android.useAndroidX=true
android.enableJetifier=true
PROPS

echo "ALL DONE!"
